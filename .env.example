# .env.example — placeholders seguros
# Não coloque segredos reais neste arquivo.

OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-to-a-long-random-secret-string

SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_USER=root
SURREAL_PASSWORD=password
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook

# Use apenas se Ollama estiver rodando como serviço no Docker Compose.
OLLAMA_BASE_URL=http://ollama:11434

# API keys devem ser configuradas pela interface do Open Notebook sempre que possível.
# OPENAI_API_KEY=sk-placeholder
# ANTHROPIC_API_KEY=placeholder
# GOOGLE_API_KEY=placeholder
# GROQ_API_KEY=placeholder
# OPENROUTER_API_KEY=placeholder
